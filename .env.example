# WireGuard Configuration
# Скопируйте этот файл в .env и настройте под свои нужды

# Публичный IP или домен сервера
SERVER_PUBLIC_IP=your_server_ip_here

# Порт WireGuard (по умолчанию 51820)
SERVER_PORT=51820

# Подсеть VPN (по умолчанию 10.0.0.0/24)
SERVER_SUBNET=10.0.0.0/24

# DNS серверы для клиентов
CLIENT_DNS=1.1.1.1,8.8.8.8

# Часовой пояс
TZ=Europe/Moscow

# Количество клиентов по умолчанию
DEFAULT_CLIENTS=3

# Имена клиентов по умолчанию (через запятую)
DEFAULT_CLIENT_NAMES=client1,client2,mobile

# Сетевой интерфейс (auto для автоопределения)
NETWORK_INTERFACE=auto
